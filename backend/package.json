{
  "name": "percare-backend",
  "version": "1.0.0",
  "description": "PerCare Requests Module - Backend API",
  "main": "app.js",
  "scripts": {
    "start":   "node app.js",
    "dev":     "nodemon app.js",
    "migrate": "psql $DATABASE_URL -f db/migrations/001_create_percare_tables.sql",
    "seed":    "node db/seed.js",
    "test":    "jest --testPathPattern=tests/ --coverage",
    "lint":    "eslint . --ext .js"
  },
  "dependencies": {
    "cors":              "^2.8.5",
    "dotenv":            "^16.3.1",
    "express":           "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet":            "^7.1.0",
    "node-cron":         "^3.0.3",
    "pg":                "^8.11.3",
    "uuid":              "^9.0.0"
  },
  "devDependencies": {
    "jest":     "^29.7.0",
    "nodemon":  "^3.0.2",
    "eslint":   "^8.55.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage"
  }
}
